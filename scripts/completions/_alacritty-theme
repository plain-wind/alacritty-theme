#compdef alacritty-theme

_alacritty-theme() {
  local -a commands themes

  commands=(
    'set:设置主题'
    'list:列出主题'
    'ls:list 的简写'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return 0
  fi

  case "${words[2]}" in
    set)
      themes=("${(@f)$(alacritty-theme list 2>/dev/null)}")
      if (( ${#themes} > 0 )); then
        _describe 'theme' themes
      else
        _message 'no themes found'
      fi
      return 0
      ;;
    list|ls)
      return 0
      ;;
    *)
      return 0
      ;;
  esac
}

compdef _alacritty-theme alacritty-theme